OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Free HF token from huggingface.co/settings/tokens (Read access is enough).
# Fixes rate-limit errors when downloading benchmark datasets at eval time.
HF_TOKEN=
# Database is SQLite, stored automatically at project root (evergreen.db)

# Optional: cache Hugging Face datasets on disk so benchmarks don't re-download
# on every restart. Set this in Replit Secrets to a path inside the project.
# HF_HOME=/home/runner/workspace/.hf_cache
